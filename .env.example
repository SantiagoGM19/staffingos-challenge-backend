# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_DATABASE=

# Session
SESSION_DRIVER=cookie

# Custom Env Vars
PASSWORD=
JSONPLACEHOLDER_URL=https://jsonplaceholder.typicode.com
JWT_SECRET=

